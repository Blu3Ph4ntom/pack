---
import { withBase } from '../../utils/base'

export interface Props {
  currentPage: string
}

const { currentPage } = Astro.props

const nav = [
  {
    group: 'Start Here',
    items: [
      { label: 'Introduction', href: '/docs/' },
      { label: 'Getting Started', href: '/docs/getting-started' },
      { label: 'Benchmarks', href: '/docs/benchmarks' },
    ],
  },
  {
    group: 'Use Pack',
    items: [
      { label: 'Commands', href: '/docs/commands' },
      { label: 'Rails Workflows', href: '/docs/rails' },
    ],
  },
]

function active(href: string) {
  return currentPage === href || (href !== '/docs/' && currentPage.startsWith(href))
}
---

<div class="sidebar">
  <div class="sidebar-header">
    <a href={withBase('/')} class="sidebar-brand" aria-label="Pack Home">
      <img src={withBase('/icon.png')} alt="Pack" class="sidebar-logo" width="36" height="36" />
      <span class="sidebar-wordmark">Pack</span>
    </a>
    <span class="sidebar-version">v0.1.4</span>
  </div>

  <p class="sidebar-tagline">Ruby package and project manager.</p>

  <nav class="sidebar-nav">
    {nav.map(section => (
      <div class="sidebar-group">
        <p class="sidebar-group-label">{section.group}</p>
        <ul class="sidebar-items">
          {section.items.map(item => (
            <li>
              <a href={withBase(item.href)} class:list={['sidebar-link', { 'is-active': active(item.href) }]}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>
  <div class="sidebar-links">
    <a href="https://github.com/Blu3Ph4ntom/pack" target="_blank" rel="noreferrer">GitHub</a>
    <a href="https://github.com/Blu3Ph4ntom/pack/releases" target="_blank" rel="noreferrer">Releases</a>
  </div>
</div>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--sp-10);
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    padding-bottom: var(--sp-4);
    border-bottom: 1px solid var(--border);
  }

  .sidebar-brand {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    color: var(--fg);
  }

  .sidebar-logo {
    width: 36px;
    height: 36px;
    border-radius: 0;
    object-fit: cover;
  }

  .sidebar-wordmark {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .sidebar-version {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--fg-muted);
    padding-top: 2px;
  }

  .sidebar-tagline {
    font-size: 12px;
    color: var(--fg-muted);
    line-height: 1.5;
    max-width: 170px;
    margin-top: calc(var(--sp-8) * -1 + var(--sp-3));
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: var(--sp-8);
  }

  .sidebar-group {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sidebar-group-label {
    font-size: 10px;
    font-weight: 700;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0 var(--sp-2);
    margin-bottom: var(--sp-2);
  }

  .sidebar-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .sidebar-link {
    display: block;
    font-size: 13px;
    color: var(--fg-secondary);
    padding: 5px 0;
    transition: color var(--duration) var(--ease);
  }

  .sidebar-link:hover { color: var(--fg); }

  .sidebar-link.is-active {
    color: var(--fg);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-color: rgba(214, 44, 73, 0.5);
    text-underline-offset: 0.2em;
  }

  .sidebar-links {
    display: flex;
    gap: var(--sp-4);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--border);
    font-size: 12px;
    color: var(--fg-muted);
  }

  .sidebar-links a:hover {
    color: var(--fg);
  }
</style>
