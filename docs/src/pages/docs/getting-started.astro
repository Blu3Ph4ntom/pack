---
import DocsLayout from '../../layouts/DocsLayout.astro'
import { withBase } from '../../utils/base'
---

<DocsLayout title="Getting Started — Pack" description="Get started with Pack, the blazingly fast Ruby package manager.">
  <a slot="sidebar" href={withBase('/docs/')} class="sidebar-home">Documentation</a>
  <nav class="sidebar-nav">
    <p class="sidebar-section">Getting Started</p>
    <a href={withBase('/docs/getting-started')} class="active">Introduction</a>
    <a href={withBase('/docs/installation')}>Installation</a>
    <a href={withBase('/docs/quick-start')}>Quick Start</a>
    <p class="sidebar-section">Commands</p>
    <a href={withBase('/docs/commands')}>All Commands</a>
    <a href={withBase('/docs/commands#install')}>pack install</a>
    <a href={withBase('/docs/commands#gem')}>pack gem</a>
    <a href={withBase('/docs/commands#exec')}>pack exec</a>
    <a href={withBase('/docs/commands#rails')}>pack rails</a>
  </nav>

  <div class="doc-content">
    <h1>Getting Started</h1>
    <p class="lead">Get up and running with Pack in under 5 minutes.</p>

    <h2>Prerequisites</h2>
    <p>Pack is a standalone binary. It doesn't require Ruby to be installed to manage gems — though your project may still need Ruby to run.</p>

    <h2>Installation</h2>
    <pre><code><span class="comment"># From source (requires Rust)</span>
cargo install pack

<span class="comment"># Or download a pre-built binary</span>
curl -fsSL https://github.com/Blu3Ph4ntom/pack/releases/latest/download/pack-linux-x86_64 -o pack
chmod +x pack
sudo mv pack /usr/local/bin/</code></pre>

    <h2>For Rails Developers</h2>
    <pre><code><span class="comment"># Create a new Rails project with Docker support</span>
pack new myapp --docker --database postgresql
cd myapp

<span class="comment"># Install gems (faster than bundle install!)</span>
pack install

<span class="comment"># Start Rails server</span>
pack server

<span class="comment"># Open Rails console</span>
pack console</code></pre>

    <h2>For Existing Projects</h2>
    <pre><code><span class="comment"># Initialize pack in existing Rails project</span>
pack init

<span class="comment"># Install gems</span>
pack install

<span class="comment"># Check for outdated gems</span>
pack outdated

<span class="comment"># See why a gem is installed</span>
pack why rails</code></pre>

    <h2>Core Commands</h2>
    <ul>
      <li><code>pack install</code> — Install gems from Gemfile</li>
      <li><code>pack add rails</code> — Add a gem to your Gemfile</li>
      <li><code>pack remove rails</code> — Remove a gem from your Gemfile</li>
      <li><code>pack update</code> — Update gem versions</li>
      <li><code>pack why rails</code> — Explain why a gem is in your dependencies</li>
      <li><code>pack exec rails console</code> — Run Rails console directly</li>
    </ul>

    <h2>Next Steps</h2>
    <p>
      <a href={withBase('/docs/commands')}>Learn all commands →</a><br>
      <a href={withBase('/docs/rails')}>Rails Support →</a>
    </p>
  </div>
</DocsLayout>

<style>
  .sidebar-home {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--fg);
    margin-bottom: var(--sp-4);
    display: block;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .sidebar-section {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: var(--sp-4);
    margin-bottom: var(--sp-2);
  }

  .sidebar-nav a {
    font-size: var(--text-sm);
    color: var(--fg-secondary);
    padding: var(--sp-1) 0;
    transition: color var(--duration) var(--ease);
  }

  .sidebar-nav a:hover,
  .sidebar-nav a.active { color: var(--fg); }

  .sidebar-nav a.active { font-weight: 500; }

  .doc-content {
    padding: var(--sp-8) var(--sp-10);
    max-width: 720px;
  }

  .doc-content h1 {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: var(--sp-4);
  }

  .doc-content h2 {
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-top: var(--sp-8);
    margin-bottom: var(--sp-4);
    padding-top: var(--sp-6);
    border-top: 1px solid var(--border);
  }

  .doc-content .lead {
    font-size: var(--text-lg);
    color: var(--fg-secondary);
    margin-bottom: var(--sp-8);
  }

  .doc-content p {
    margin-bottom: var(--sp-4);
    line-height: 1.7;
  }

  .doc-content ul {
    margin-bottom: var(--sp-6);
    padding-left: var(--sp-6);
  }

  .doc-content li {
    margin-bottom: var(--sp-2);
  }

  .doc-content li code {
    color: var(--accent);
  }

  .doc-content pre {
    background: var(--bg-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--sp-4);
    margin-bottom: var(--sp-6);
    overflow-x: auto;
  }

  .doc-content code {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    background: none;
    border: none;
    padding: 0;
  }

  .doc-content pre code {
    color: var(--fg);
  }

  .doc-content .comment { color: var(--fg-muted); }
  .doc-content .success { color: var(--green); }

  .doc-content a {
    color: var(--accent);
    line-height: 2;
  }
</style>
