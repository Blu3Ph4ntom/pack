---
import LandingLayout from '../layouts/LandingLayout.astro'
import Navbar from '../components/landing/Navbar.astro'
import Hero from '../components/landing/Hero.astro'
import ProblemSection from '../components/landing/ProblemSection.astro'
import SolutionSection from '../components/landing/SolutionSection.astro'
import FeaturesGrid from '../components/landing/FeaturesGrid.astro'
import UseCasesSection from '../components/landing/UseCasesSection.astro'
import BenchmarksSection from '../components/landing/BenchmarksSection.astro'
import CTASection from '../components/landing/CTASection.astro'
import Footer from '../components/landing/Footer.astro'
---

<LandingLayout title="Pack — Ruby tooling with Bun energy" description="Pack is a Rust-powered Ruby package manager and Rails workflow CLI. Fast parsing, gem verbs, Packfile tasks, diagnostics, and Rails-first commands.">
  <Navbar />
  <Hero />
  <ProblemSection />
  <SolutionSection />
  <FeaturesGrid />
  <UseCasesSection />
  <BenchmarksSection />
  <CTASection />
  <Footer />
</LandingLayout>
