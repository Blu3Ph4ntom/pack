---
import '../styles/global.css'
import { withBase } from '../utils/base'

interface Props {
  title: string
  description?: string
}

const { title, description = 'Pack Documentation' } = Astro.props
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0a0a0f" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body>
  <div class="docs-shell">
    <aside class="docs-side" x-data="{ open: false }" :class="{ 'is-open': open }">
      <slot name="sidebar" />
    </aside>
    <main class="docs-main">
      <slot />
    </main>
    <aside class="docs-toc">
      <slot name="toc" />
    </aside>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const io = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('is-visible') })
      }, { threshold: 0.08 })
      document.querySelectorAll('[data-reveal],[data-stagger]').forEach(el => io.observe(el))
    })
  </script>
</body>
</html>

<style>
  .docs-shell {
    display: grid;
    grid-template-columns: 280px 1fr 320px;
    min-height: 100vh;
  }

  .docs-side {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    padding: var(--sp-6) var(--sp-5);
    border-right: 1px solid var(--border);
    background: var(--bg);
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  .docs-main {
    min-width: 0;
  }

  .docs-toc {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    padding: var(--sp-6) var(--sp-5);
    border-left: 1px solid var(--border);
    background: linear-gradient(90deg, var(--bg) 0%, rgba(10,10,15,0.5) 100%);
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  @media (max-width: 1400px) {
    .docs-shell { grid-template-columns: 280px 1fr 280px; }
  }

  @media (max-width: 1200px) {
    .docs-shell { grid-template-columns: 280px 1fr; }
    .docs-toc { display: none; }
  }

  @media (max-width: 960px) {
    .docs-shell { grid-template-columns: 1fr; }
    .docs-side {
      position: fixed;
      inset: 0;
      width: 280px;
      z-index: 100;
      transform: translateX(-100%);
      transition: transform var(--duration) var(--ease);
    }
    .docs-side.is-open { transform: none; }
  }
</style>
