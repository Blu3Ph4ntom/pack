---
export interface Props {
  type?: 'note' | 'tip' | 'warning'
  title?: string
}

const { type = 'note', title } = Astro.props

const labels: Record<string, string> = {
  note: 'Note',
  tip: 'Tip',
  warning: 'Warning',
}
---

<div class={`callout callout--${type}`}>
  <p class="callout-label">{title ?? labels[type]}</p>
  <div class="callout-body">
    <slot />
  </div>
</div>

<style>
  .callout {
    padding: var(--sp-4) var(--sp-5);
    border-radius: var(--radius-sm);
    border-left: 2px solid var(--border);
    background: var(--bg-subtle);
    margin: var(--sp-5) 0;
  }

  .callout--note { border-left-color: var(--fg-muted); }
  .callout--tip { border-left-color: var(--accent); }
  .callout--warning { border-left-color: var(--amber); }

  .callout-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-muted);
    margin-bottom: var(--sp-2);
  }

  .callout--tip .callout-label {
    color: #ffdbe1;
  }

  .callout--warning .callout-label {
    color: var(--amber);
  }

  .callout-body {
    font-size: var(--text-sm);
    color: var(--fg-secondary);
    line-height: 1.6;
  }

  .callout-body p {
    margin-bottom: var(--sp-2);
  }

  .callout-body p:last-child {
    margin-bottom: 0;
  }
</style>
