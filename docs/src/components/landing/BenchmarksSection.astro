---
---

<section class="sect" id="benchmarks">
  <div class="wrap">

    <p class="sect-eyebrow" data-reveal>Performance</p>
    <h2 class="sect-heading" data-reveal>Measured in operations<br />per second.</h2>

    <div class="bench-table" data-stagger>
      <div class="bench-row bench-row--head">
        <span>Operation</span>
        <span>Bundler</span>
        <span>Pack</span>
        <span>Speedup</span>
      </div>
      <div class="bench-row">
        <span class="bench-op">Parse Gemfile (100 deps)</span>
        <span class="bench-val bench-slow">850ms</span>
        <span class="bench-val bench-fast">5µs</span>
        <span class="bench-val accent">157,000x</span>
      </div>
      <div class="bench-row">
        <span class="bench-op">Parse Gemfile.lock (50 gems)</span>
        <span class="bench-val bench-slow">500ms</span>
        <span class="bench-val bench-fast">15µs</span>
        <span class="bench-val accent">33,000x</span>
      </div>
      <div class="bench-row">
        <span class="bench-op">Parse Gemfile.lock (200 gems)</span>
        <span class="bench-val bench-slow">1200ms</span>
        <span class="bench-val bench-fast">41µs</span>
        <span class="bench-val accent">29,000x</span>
      </div>
      <div class="bench-row">
        <span class="bench-op">Startup time</span>
        <span class="bench-val bench-slow">500ms</span>
        <span class="bench-val bench-fast">1ms</span>
        <span class="bench-val accent">500x</span>
      </div>
      <div class="bench-row">
        <span class="bench-op">Gem list command</span>
        <span class="bench-val bench-slow">200ms</span>
        <span class="bench-val bench-fast">1ms</span>
        <span class="bench-val accent">200x</span>
      </div>
    </div>

    <p class="bench-note" data-reveal>
      Benchmark machine: AMD EPYC 7662, 2024. Pack times are pure Rust execution.
      Bundler times include Ruby interpreter startup (~500ms).
    </p>

  </div>
</section>

<style>
  .sect {
    padding: var(--sp-24) 0;
    border-top: 1px solid var(--border);
  }

  .sect-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--sp-4);
  }

  .sect-heading {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-3xl));
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: var(--sp-12);
  }

  .bench-table {
    border-top: 1px solid var(--border);
    margin-bottom: var(--sp-8);
  }

  .bench-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    justify-content: space-between;
    align-items: center;
    padding: var(--sp-4) 0;
    border-bottom: 1px solid var(--border);
  }

  .bench-row--head {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .bench-op {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-secondary);
  }

  .bench-val {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg);
    font-weight: 500;
    text-align: right;
  }

  .bench-val.bench-slow { color: var(--fg-muted); text-decoration: line-through; }
  .bench-val.bench-fast { color: var(--green); }
  .bench-val.accent { color: var(--accent); }

  .bench-note {
    font-size: var(--text-sm);
    color: var(--fg-secondary);
    line-height: 1.55;
  }

  @media (max-width: 640px) {
    .bench-row { grid-template-columns: 1fr 1fr; gap: var(--sp-2); }
    .bench-row--head { display: none; }
    .bench-val { text-align: left; }
  }
</style>
