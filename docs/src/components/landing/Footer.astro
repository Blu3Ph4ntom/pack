---
import { withBase } from '../../utils/base'
---

<footer class="footer">
  <div class="wrap footer-inner">

    <div class="footer-brand">
      <a href={withBase('/')} class="footer-logo">Pack</a>
      <p class="footer-tagline">Blazingly fast Ruby package manager. Built with Rust.</p>
    </div>

    <nav class="footer-nav">
      <div class="footer-col">
        <p class="footer-col-head">Docs</p>
        <a href={withBase('/docs/')}>Introduction</a>
        <a href={withBase('/docs/getting-started')}>Getting Started</a>
        <a href={withBase('/docs/commands')}>Commands</a>
        <a href={withBase('/docs/rails')}>Rails Support</a>
      </div>
      <div class="footer-col">
        <p class="footer-col-head">Project</p>
        <a href="https://github.com/Blu3Ph4ntom/pack" target="_blank" rel="noopener">GitHub</a>
        <a href="https://crates.io/crates/pack" target="_blank" rel="noopener">crates.io</a>
        <a href="https://github.com/Blu3Ph4ntom/pack/blob/main/CHANGELOG.md" target="_blank" rel="noopener">Changelog</a>
        <a href="https://github.com/Blu3Ph4ntom/pack/blob/main/LICENSE" target="_blank" rel="noopener">MIT License</a>
      </div>
      <div class="footer-col">
        <p class="footer-col-head">Compare</p>
        <a href={withBase('/docs/#benchmarks')}>Benchmarks</a>
        <a href={withBase('/docs/commands#gem')}>vs gem</a>
        <a href={withBase('/docs/commands#bundle')}>vs Bundler</a>
      </div>
    </nav>

  </div>

  <div class="footer-bottom">
    <div class="wrap footer-bottom-inner">
      <span>© 2025 Blu3Ph4ntom · MIT License</span>
      <span>pack v0.1.0 · Rust-Powered</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding-top: var(--sp-16);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--sp-16);
    padding-bottom: var(--sp-16);
  }

  .footer-logo {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--fg);
    display: block;
    margin-bottom: var(--sp-3);
    letter-spacing: -0.02em;
  }

  .footer-tagline {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    line-height: 1.5;
    max-width: 220px;
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-8);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .footer-col-head {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--sp-1);
  }

  .footer-col a {
    font-size: var(--text-sm);
    color: var(--fg-secondary);
    transition: color var(--duration) var(--ease);
  }

  .footer-col a:hover { color: var(--fg); }

  .footer-bottom {
    border-top: 1px solid var(--border);
    padding: var(--sp-5) 0;
  }

  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-bottom span {
    font-size: var(--text-xs);
    color: var(--fg-muted);
    font-family: var(--font-mono);
  }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr; gap: var(--sp-10); }
    .footer-nav { grid-template-columns: repeat(2, 1fr); }
    .footer-bottom-inner { flex-direction: column; gap: var(--sp-2); text-align: center; }
  }

  @media (max-width: 480px) {
    .footer-nav { grid-template-columns: 1fr; }
  }
</style>
