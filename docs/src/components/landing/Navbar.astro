---
import { withBase } from '../../utils/base'
---

<header class="nav" x-data="{ open: false }">
  <div class="wrap nav-inner">
    <a href={withBase('/')} class="nav-brand" aria-label="Pack Home">
      <img src={withBase('/logo.png')} alt="Pack" class="nav-logo" width="36" height="36" />
      <span class="nav-wordmark">Pack</span>
    </a>

    <nav class="nav-links" :class="{ 'is-open': open }">
      <a href="#features">Features</a>
      <a href="#benchmarks">Performance</a>
      <a href={withBase('/docs/')}>Docs</a>
      <a href="https://github.com/Blu3Ph4ntom/pack" target="_blank" rel="noopener">GitHub</a>
    </nav>

    <div class="nav-actions">
      <a href={withBase('/docs/getting-started')} class="nav-cta">Get Started</a>
      <button class="nav-burger" @click="open = !open" :aria-expanded="open" aria-label="Menu">
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    height: var(--nav-h);
    background: rgba(10, 10, 15, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    height: 100%;
    gap: var(--sp-8);
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-right: auto;
    text-decoration: none;
    transition: opacity var(--duration) var(--ease);
    color: var(--fg);
  }

  .nav-brand:hover { opacity: 0.8; text-decoration: none; }

  .nav-logo {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    object-fit: cover;
    box-shadow: 0 0 24px rgba(171, 27, 51, 0.24);
  }

  .nav-wordmark {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--sp-6);
  }

  .nav-links a {
    font-size: var(--text-sm);
    color: var(--fg-secondary);
    transition: color var(--duration) var(--ease);
    font-weight: 500;
  }

  .nav-links a:hover { color: var(--fg); text-decoration: none; }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }

  .nav-cta {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--accent-fg);
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-bright) 100%);
    padding: 0.5rem 1rem;
    border-radius: var(--radius);
    transition: transform var(--duration) var(--ease), opacity var(--duration) var(--ease);
  }

  .nav-cta:hover { opacity: 0.9; transform: translateY(-1px); text-decoration: none; }

  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: flex-end;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--sp-1);
    width: 32px;
    height: 32px;
  }

  .nav-burger span {
    display: block;
    height: 2px;
    background: var(--fg);
    border-radius: 10px;
    transition: width var(--duration) var(--ease), transform var(--duration) var(--ease);
  }

  .nav-burger span:nth-child(1) { width: 20px; }
  .nav-burger span:nth-child(2) { width: 14px; }

  @media (max-width: 768px) {
    .nav-inner { gap: 0; }
    .nav-cta { display: none; }
    .nav-burger { display: flex; }

    .nav-links {
      position: fixed;
      inset: var(--nav-h) 0 0 0;
      background: var(--bg);
      flex-direction: column;
      align-items: flex-start;
      padding: var(--sp-8);
      gap: var(--sp-6);
      border-top: 1px solid var(--border);
      transform: translateY(-8px);
      opacity: 0;
      pointer-events: none;
      transition: transform 0.3s var(--ease), opacity 0.3s var(--ease);
    }

    .nav-links.is-open {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .nav-links a { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.02em; }
  }
</style>
