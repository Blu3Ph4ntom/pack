---
import { withBase } from '../../utils/base'
---

<section class="hero">
  <div class="wrap hero-inner">
    <p class="hero-tag" data-reveal x-data="{ copied: false }">
      <span class="hero-dot"></span>
      <code>gem install pack-rb</code>
      <button
        class="hero-copy"
        @click="navigator.clipboard.writeText('gem install pack-rb').then(() => { copied = true; setTimeout(() => copied = false, 2000); })"
        aria-label="Copy install command"
      >
        <svg x-show="!copied" class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
        <svg x-show="copied" class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </button>
    </p>

    <h1 class="hero-h" data-reveal>
      Bun energy for Ruby.<br /><span class="gradient-text">Built for Rails reality.</span>
    </h1>

    <p class="hero-sub" data-reveal>
      Pack is a Rust-powered CLI for Ruby developers who want the `gem`, Bundler,
      and Rails workflow to feel modern again.
    </p>

    <div class="hero-actions" data-reveal>
      <a href={withBase('/docs/getting-started')} class="btn-solid">Get Started</a>
      <a href="https://github.com/Blu3Ph4ntom/pack" target="_blank" rel="noopener" class="btn-ghost">GitHub</a>
    </div>

    <div class="hero-bench" data-reveal>
      <div class="bench-row">
        <span class="bench-label">Bundler</span>
        <div class="bench-track"><div class="bench-fill bench-slow"></div></div>
        <span class="bench-num">850ms</span>
      </div>
      <div class="bench-row">
        <span class="bench-label">Pack</span>
        <div class="bench-track"><div class="bench-fill bench-fast"></div></div>
        <span class="bench-num is-highlight">5µs</span>
      </div>
    </div>

    <p class="hero-subtitle" data-reveal>
      Drop-in framing: <strong>install</strong>, <strong>list</strong>, <strong>search</strong>, <strong>exec</strong>, <strong>doctor</strong>, Rails helpers, and binary <strong>pack.lock</strong>
    </p>
  </div>
</section>

<style>
  .hero {
    padding: calc(var(--nav-h) + var(--sp-20)) 0 var(--sp-20);
    text-align: center;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    padding: var(--sp-1) var(--sp-3);
    margin-bottom: var(--sp-8);
  }

  .hero-tag code { font-size: inherit; }

  .hero-copy {
    color: var(--fg-muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 2px;
    margin-left: 4px;
    display: flex;
    align-items: center;
    transition: color 150ms var(--ease);
  }

  .hero-copy:hover { color: var(--fg-secondary); }
  .hero-copy:active { color: var(--green); }

  .copy-icon { width: 12px; height: 12px; }

  .hero-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .hero-h {
    font-size: clamp(var(--text-4xl), 8vw, var(--text-5xl));
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--fg);
    margin-bottom: var(--sp-6);
    max-width: 820px;
  }

  .gradient-text {
    background: linear-gradient(135deg, #f3d5db 0%, #d62c49 40%, #ab1b33 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: var(--text-lg);
    line-height: 1.6;
    color: var(--fg-secondary);
    max-width: 620px;
    margin-bottom: var(--sp-10);
  }

  .hero-subtitle {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    margin-top: var(--sp-6);
  }

  .hero-subtitle strong { color: var(--accent); }

  .hero-actions {
    display: flex;
    gap: var(--sp-3);
    margin-bottom: var(--sp-16);
  }

  .btn-solid {
    font-size: var(--text-sm);
    font-weight: 500;
    color: white;
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-bright) 100%);
    padding: var(--sp-2) var(--sp-5);
    border-radius: var(--radius-sm);
    transition: opacity var(--duration) var(--ease);
  }

  .btn-solid:hover { opacity: 0.85; text-decoration: none; }

  .btn-ghost {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--fg-secondary);
    padding: var(--sp-2) var(--sp-5);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    transition: color var(--duration) var(--ease), border-color var(--duration) var(--ease);
  }

  .btn-ghost:hover { color: var(--fg); border-color: var(--border-hover); text-decoration: none; }

  .hero-bench {
    width: 100%;
    max-width: 420px;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .bench-row {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
  }

  .bench-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    width: 60px;
    text-align: right;
  }

  .bench-track {
    flex: 1;
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .bench-fill {
    height: 100%;
    border-radius: 2px;
    animation: grow 1.2s var(--ease) forwards;
  }

  .bench-slow { width: 10%; background: var(--fg-muted); }
  .bench-fast { width: 100%; background: linear-gradient(90deg, var(--accent), var(--accent-dim)); }

  .bench-num {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    width: 60px;
    text-align: left;
  }

  .bench-num.is-highlight { color: var(--accent); }

  @keyframes grow {
    from { width: 0; }
  }

  @media (max-width: 640px) {
    .hero { padding: calc(var(--nav-h) + var(--sp-12)) 0 var(--sp-12); }
    .hero-sub br { display: none; }
  }
</style>
