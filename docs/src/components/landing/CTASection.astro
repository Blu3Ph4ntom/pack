---
import { withBase } from '../../utils/base'
---

<section class="sect">
  <div class="wrap">

    <div class="cta-inner" data-reveal>
      <h2 class="cta-heading">Ready to speed up your Ruby workflow?</h2>
      <p class="cta-sub">Install Pack and experience gem management without the wait.</p>
      <div class="cta-actions">
        <a href={withBase('/docs/getting-started')} class="btn-solid">Get Started</a>
        <a href="https://github.com/Blu3Ph4ntom/pack" target="_blank" rel="noopener" class="btn-ghost">View on GitHub</a>
      </div>
    </div>

  </div>
</section>

<style>
  .sect {
    padding: var(--sp-32) 0;
    border-top: 1px solid var(--border);
  }

  .cta-inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-heading {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-3xl));
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.03em;
    margin-bottom: var(--sp-4);
  }

  .cta-sub {
    font-size: var(--text-lg);
    color: var(--fg-secondary);
    margin-bottom: var(--sp-8);
  }

  .cta-actions {
    display: flex;
    gap: var(--sp-3);
    justify-content: center;
  }

  .btn-solid {
    font-size: var(--text-sm);
    font-weight: 500;
    color: white;
    background: var(--accent);
    padding: var(--sp-3) var(--sp-6);
    border-radius: var(--radius-sm);
    transition: opacity var(--duration) var(--ease);
  }

  .btn-solid:hover { opacity: 0.85; text-decoration: none; }

  .btn-ghost {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--fg-secondary);
    padding: var(--sp-3) var(--sp-6);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    transition: color var(--duration) var(--ease), border-color var(--duration) var(--ease);
  }

  .btn-ghost:hover { color: var(--fg); border-color: var(--border-hover); text-decoration: none; }

  @media (max-width: 540px) {
    .cta-actions { flex-direction: column; }
  }
</style>
